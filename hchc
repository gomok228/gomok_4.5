public void ClearLevelOnDeath()
{
    // Останавливаем музыку босса или уровня
    if (SoundManager.Instance != null) SoundManager.Instance.StopMusic();

    // Удаляем врагов, чтобы они не мешали сцене смерти
    GameObject[] enemies = GameObject.FindGameObjectsWithTag("Enemy");
    foreach (var enemy in enemies)
    {
        Destroy(enemy);
    }

    // Чистим ТОЛЬКО те пули и взрывы, которые уже есть на сцене
    // Это не мешает игроку стрелять, пока он жив
    string[] tagsToClean = { "Explosion", "Bomb", "Bullet", "EnemyBullet" };
    foreach (var tag in tagsToClean)
    {
        GameObject[] objs = GameObject.FindGameObjectsWithTag(tag);
        foreach (var o in objs) Destroy(o);
    }
    
    Debug.Log("Уровень очищен после смерти игрока");
}
